# --- Documentos de trabajo (no versionar) ---
# Carpeta de contexto interno del desarrollador (Kike): documentos de referencia y apoyo
# (Prompts.docx, descripcion_proyecto.docx, glosario, etc.). Uso interno, NO es parte del producto.
Contexto_para_mi/

# --- Locks temporales de LibreOffice/OpenOffice ---
.~lock.*#

# --- Secretos / entorno ---
.env
# Secretos locales de Streamlit (en Community Cloud se gestionan desde el panel)
.streamlit/secrets.toml

# --- Python ---
__pycache__/
*.pyc
venv/
.venv/

# --- Persistencia interna de la app (SQLite) ---
.data/
# Sidecars del WAL (defensa en profundidad por si el .db se ubica fuera de .data/)
*.db-wal
*.db-shm

# --- RECURSOS: conservar la estructura de carpetas vacía, ignorar su contenido ---
# Ignora todo el contenido de RECURSOS/ ...
RECURSOS/**
# ... pero conserva las propias carpetas vía sus .gitkeep
!RECURSOS/
!RECURSOS/**/
!RECURSOS/**/.gitkeep
!RECURSOS/.gitkeep

prueba_investigador.py

Informes/
