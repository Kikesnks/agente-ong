# Claves API del proyecto agente-ong
# Copia este archivo a .env y rellena con tus claves.
# En Streamlit Cloud, configura las mismas variables en Settings → Secrets.

# Tavily (búsqueda web) — opcional pero recomendada. Sin ella solo se usan BDNS/TED.
TAVILY_API_KEY=tvly-tu_clave_aqui

# Firecrawl (fallback de lectura de páginas) — opcional. Sin ella se usa solo el lector
# interno (HttpReaderSource, sin coste), que es la fuente primaria en cualquier caso.
FIRECRAWL_API_KEY=fc-tu_clave_aqui

# BDNS y TED son APIs públicas — no necesitan clave. BDNS_API_KEY/TED_API_KEY existen en
# ResearchConfig reservadas para el futuro, pero ninguna fuente las usa hoy.
# BDNS_API_KEY=
# TED_API_KEY=

# --- Otras variables opcionales (ver ResearchConfig.from_env() en research/config.py) ---

# Año mínimo de las convocatorias devueltas por las fuentes que lo soportan (BDNS/Tavily
# en cliente, TED en servidor). Sin definir: BDNS/Tavily sin filtro, TED usa el año anterior.
# RESEARCH_MIN_YEAR=2024

# Vocabulario de OFERTA de financiación que orienta las búsquedas de texto libre en Tavily
# (R16), separado por comas. Sin definir, usa el default de config.py.
# RESEARCH_CALL_VOCABULARY=convocatoria,subvención,ayudas,bases reguladoras,plazo de presentación

# Ruta del material de entrenamiento recolectado en modo "training". Por defecto:
# RECURSOS/ENTRENAMIENTO (relativa a la raíz del repo).
# RECURSOS_ENTRENAMIENTO_PATH=RECURSOS/ENTRENAMIENTO

# Ruta de la base de datos SQLite de persistencia (proyectos, runs, ledger). Por defecto:
# .data/agente_ong.db (relativa a la raíz del repo).
# RESEARCH_DB_PATH=.data/agente_ong.db

# Límites de la investigación (enteros). Prioridad calidad > velocidad, acotada para
# evitar bucles o costes descontrolados.
# RESEARCH_MAX_DEPTH=3
# RESEARCH_MAX_PAGES=50
# RESEARCH_MAX_QUERIES=30
# RESEARCH_STALENESS_DAYS=30

# Límites de longitud del contenido en el informe (caracteres).
# RESEARCH_SNIPPET_MAX_CHARS=300
# RESEARCH_ORGANISM_MAX_CHARS=200

# Nº máximo de llamadas al detalle de BDNS por investigación.
# RESEARCH_BDNS_MAX_DETAIL_CALLS=20

# Nº máximo de páginas leídas en profundidad por investigación (coexiste con
# RESEARCH_MAX_PAGES; gana el menor).
# RESEARCH_READER_MAX_PAGES=15

# Nº máximo de llamadas al fallback Firecrawl por investigación. 0 = nunca (coste cero
# garantizado por defecto; el lector interno es el primario y no tiene coste).
# RESEARCH_FIRECRAWL_MAX_CALLS=0
